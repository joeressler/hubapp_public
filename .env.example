# Copy to .env and fill in values before running docker compose up.
# Compose reads .env automatically for ${VAR} substitution in docker-compose.yml.
MYSQL_HOST=
MYSQL_USER=
MYSQL_PWD=
MYSQL_DATABASE=
FLASK_SECRET_KEY=change-me
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
VERIFY_URL=
PASSWORD_PIN=
SENTRY_DSN=
OPENAI_API_KEY=

# Backend -> internal spell ECS microservice (Docker network only; not exposed publicly)
SPELL_ECS_URL=http://spell-ecs:8082
SPELL_ECS_TIMEOUT=300

# Spell ECS microservice (Granite 4.1 3B via llama-cpp-python)
GRANITE_MODEL_REPO=ibm-granite/granite-4.1-3b-GGUF
GRANITE_MODEL_FILE=*Q4_K_M.gguf
GRANITE_MODEL_PATH=
GRANITE_N_CTX=4096
GRANITE_N_GPU_LAYERS=0
GRANITE_MAX_TOKENS=1024
