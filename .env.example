# Copy to .env and fill in values before running docker compose up.
# Compose reads .env automatically for ${VAR} substitution in docker-compose.yml.

# Database
MYSQL_HOST=
MYSQL_USER=
MYSQL_PWD=
MYSQL_DATABASE=

# Flask — use a long random string in production (e.g. openssl rand -hex 32)
FLASK_SECRET_KEY=

# Shared secret for backend <-> voice service communication
INTERNAL_SERVICE_KEY=

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=
VERIFY_URL=https://www.google.com/recaptcha/api/siteverify

# Optional admin password-reset PIN (not exposed via API)
PASSWORD_PIN=

# Error monitoring (https://sentry.io)
SENTRY_DSN=

# OpenAI API key for RAG chatbot
OPENAI_API_KEY=

# Frontend build-time reCAPTCHA site key (same as RECAPTCHA_PUBLIC_KEY)
REACT_APP_RECAPTCHA_PUBLIC_KEY=

# Optional frontend Sentry DSN
REACT_APP_SENTRY_DSN=
